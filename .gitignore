# =============================================================================
# NexVas — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Private / internal — not for the open-source repo
# -----------------------------------------------------------------------------
.claude/
CLAUDE.md
dev-corner/

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/

# -----------------------------------------------------------------------------
# Build output
# -----------------------------------------------------------------------------
dist/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Docs build
# -----------------------------------------------------------------------------
docs/.vitepress/dist/
docs/.vitepress/cache/

# -----------------------------------------------------------------------------
# Test output
# -----------------------------------------------------------------------------
coverage/
.vitest-attachments/
test-results/
playwright-report/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
pnpm-debug.log*
npm-debug.log*
yarn-debug.log*

# -----------------------------------------------------------------------------
# Environment / local config
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.local

# -----------------------------------------------------------------------------
# OS / editor noise
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
.idea/
*.suo
*.user
